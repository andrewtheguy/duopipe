# duopipe peer configuration example
#
# Usage: duopipe run -c peer.toml
#        duopipe run                  # loads ~/.config/duopipe/peer.toml
#
# This file is read by CONFIG MODE (`duopipe run`): the listener publishes its
# current ephemeral node id to nostr and a dialer looks it up, so the node id need
# not be exchanged by hand. The auth token (the nostr rendezvous secret) is OPTIONAL
# in this file — set 'auth_token_file' below or the DUOPIPE_AUTH_TOKEN env var, or
# leave both unset and paste it at the setup screen. Either way it must be pre-shared:
# generate one with `duopipe generate-auth-token` and use the same value on every
# peer. The other mode is configless (`duopipe quick`): the id and token are
# ephemeral, and setup lets you choose either a rotating PIN over nostr or manual
# copy-paste of the node id and generated token.
#
# `duopipe run` is interactive and opens idle. There is no startup listen/dial role
# choice and no dial target in this file: press Shift-L to start/stop listening, then
# press Shift-C on the dashboard and type the target peer's `name` to start the single
# outbound dial session. This file supplies the shared auth token, this peer's own
# `name`, the single tunnel, relays, tuning, and the nostr relay override.
#
# Tunnel model: every node always serves inbound peers AND can open one outbound TCP
# tunnel on demand over its dial session. The [tunnel] table is that single tunnel:
# it binds a local listener and asks the connected peer to connect out to a remote
# 'remote_source' (a bare host:port, TCP), bridging the two. It does NOT start
# automatically — the TUI shows it and you start/stop it with `s`/`x` (in test mode
# only, with DUOPIPE_TEST_MODE=1, set DUOPIPE_AUTOSTART_TUNNELS=1 to auto-start once
# connected). Inbound, this peer serves any number of dialers at once.
#
# Trust model: once token auth succeeds the connected peer is fully trusted — it may
# ask us to connect out to any host:port (there is no source allowlist). Keep the
# shared token only on devices you own (or otherwise fully trust).
#
# Node id: the iroh identity key is always ephemeral (regenerated every run), so a
# listening instance's node id changes between runs. nostr is used as a side
# channel to publish & look up the current node id, keyed off the shared auth_token
# (see 'nostr_*' below), so a dialer can connect without copying the node id.

# This peer's short, memorable identifier. REQUIRED in config mode. When listening,
# this peer publishes its node id under this name; another peer dials it by typing
# this name. Several peers can share one auth token and be reached by name (duplicate
# names just mean newest-wins). For the raw node-id flow, use quick mode (`duopipe quick`).
name = "web1"

# The shared auth token, presented by both sides (it is also the nostr rendezvous
# secret). OPTIONAL here: supply it via 'auth_token_file' (recommended) or the
# DUOPIPE_AUTH_TOKEN env var; if you set neither, setup prompts you to paste it.
# It must be pre-shared and identical on every peer — generate it once with:
#   duopipe generate-auth-token
# The token's fingerprint (the first 8 hex digits of its SHA-256) is shown in the
# dashboard header so both devices can confirm they share the same token even after
# it is hidden.
auth_token_file = "~/.config/duopipe/token.txt"

# The shared token's fingerprint — the first 8 hex digits of its SHA-256. REQUIRED in
# config mode, whether or not the token itself is set above. Whatever token is resolved —
# from 'auth_token_file', the DUOPIPE_AUTH_TOKEN env var, or pasted at the setup
# screen — must match this fingerprint, or duopipe refuses to start. This pins each
# config to one pairing, so pointing it at the wrong token file (or pasting a token
# meant for a different pair of devices) is caught up front instead of failing as an
# auth error later. Find the value with `duopipe generate-auth-token` (printed
# alongside the token) or read it from the dashboard header ("token fp"). Case-
# insensitive.
auth_token_fingerprint = "a1b2c3d4"

# Nostr node-id discovery is active whenever a config file is loaded. Both peers
# derive a shared nostr key from the auth_token above; the listener publishes its
# current ephemeral node id under its 'name' and the dialer looks it up by that
# name, so the node id never has to be exchanged by hand. The published node id is
# encrypted (NIP-44) under the shared auth_token-derived key, and the 'name' is
# hashed (salted with the auth_token) into the lookup key — so neither the node id
# nor the name can be read or guessed off the relays without the token. The
# auth_token still gates the actual connection.
#
# Relays default to a built-in public set; override here if you want specific ones:
# nostr_relay_urls = ["wss://nos.lol", "wss://relay.nostr.net"]

# Maximum concurrent forwarded data streams, shared across all connected peers
# (default: 100).
# max_streams = 100

# Custom relay server URL(s) for failover. Defaults to iroh's public relays.
# relay_urls = ["https://relay1.example.com", "https://relay2.example.com"]

# Force all traffic through the relay (disables direct P2P). Requires at least
# one entry in relay_urls (the public relay is rate-limited and not allowed here).
# relay_only = true

# Custom DNS server URL for iroh endpoint discovery (pkarr), or "none" to disable
# DNS discovery. NOT system DNS; does not affect destination resolution.
# NOTE: URL must include the /pkarr path. Both peers must match.
# dns_server = "https://dns.example.com/pkarr"
# dns_server = "none"

# ============================================================================
# The single TCP tunnel this node can open over its outbound dial session: ask the
# connected peer to connect out to 'remote_source' (a bare host:port, TCP); deliver
# traffic to a local listener bound at 'local_listen'. Optional — in quick mode it is
# set from the TUI instead. Nothing starts until you connect to a peer and activate it
# (`s` in the TUI, or DUOPIPE_AUTOSTART_TUNNELS=1 in test mode). The tunnel can also
# be set (e) or cleared (d) from the dashboard at runtime (while not running).
# ============================================================================
[tunnel]
remote_source = "127.0.0.1:5678"
local_listen = "127.0.0.1:15678"

# ============================================================================
# Transport Tuning (Optional)
# ============================================================================
# Fine-tune the QUIC transport layer. All values have sensible defaults.
[transport]
# Congestion controller: cubic (default), bbr, or newreno.
# congestion_controller = "cubic"

# QUIC per-stream receive window in bytes (default: 67108864 = 64MB).
# Valid range: 1024 (1KB) to 67108864 (64MB).
# receive_window = 67108864

# QUIC send window in bytes (default: 67108864 = 64MB).
# send_window = 67108864

# QUIC ACK-eliciting threshold (default: unset = iroh/quinn default cadence).
# Leave unset unless you have measured a benefit. 0 = ACK every packet.
# Valid range: 0 to 65535.
# ack_eliciting_threshold = 2
