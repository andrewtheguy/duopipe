# duopipe peer configuration example
#
# Usage: duopipe nostr -c peer.toml
#        duopipe nostr                    # loads ~/.config/duopipe/peer.toml
#
# This file is read by NOSTR MODE (`duopipe nostr`): the listener publishes its
# current ephemeral node id to nostr and a dialer looks it up, so the node id need
# not be exchanged by hand. Nostr mode REQUIRES a provided auth token (it is the
# nostr rendezvous secret) — set 'auth_token_file' below or the DUOPIPE_AUTH_TOKEN
# env var. The other mode is configless (`duopipe quick`): the id and token are
# ephemeral, nostr is off, and the dialer enters the node id by hand (supply a
# token there with `duopipe quick --auth-token-file <path>`).
#
# `duopipe nostr` is interactive: on startup the TUI asks whether to connect to an
# existing instance. The role (dial/listen) and the target node id are answered
# there — they are NOT config keys. In nostr mode the node id can be left blank to
# discover it via nostr. This file supplies the rest: the shared auth token, tunnel
# requests, the allowlist, relays, tuning, and the nostr relay override.
#
# Tunnel model: a side *requests* tunnels from a connected peer. A request binds a
# local listener and asks the peer to connect out to a remote 'source'; traffic is
# bridged between them. [[request]] is a PREFILLED TEMPLATE that seeds the tunnel
# list for every connection (to save typing); tunnels are STARTED MANUALLY in the
# TUI with Enter — nothing auto-connects (in test mode only, with DUOPIPE_TEST_MODE=1,
# set DUOPIPE_AUTOSTART_REQUESTS=1 to auto-start a peer's tunnels on connect).
#
# Multiple peers: a listener serves many dialers at once. Tunnel state is per peer —
# each connection gets its own copy of the template list. The TUI shows a peer list
# and the selected peer's tunnels; press Tab to switch focus, so a tunnel you start
# targets exactly that peer.
#
# Trust model: once token auth succeeds the peer is trusted to *ask*, but when it
# requests one of OUR sources we only honor addresses inside [allowed_sources]
# (separate CIDR lists per protocol). Empty/absent TCP or UDP defaults to
# dual-stack localhost.
#
# Node id: the iroh identity key is always ephemeral (regenerated every run), so a
# listening instance's node id changes between runs. nostr is used as a side
# channel to publish & look up the current node id, keyed off the shared auth_token
# (see 'nostr_*' below), so a dialer can connect without copying the node id.

# This peer's short, memorable identifier. REQUIRED in nostr mode. When listening,
# this peer publishes its node id under this name; a dialer types it to find this
# peer. Several peers can share one auth token and be reached individually by name
# (duplicate names just mean newest-wins). For the raw node-id flow, use quick mode
# (`duopipe quick`).
name = "web1"

# The shared auth token, presented by both sides. REQUIRED in nostr mode (it is
# the nostr rendezvous secret). Generate with:
#   duopipe generate-auth-token
# Supply it via 'auth_token_file' (recommended) or the DUOPIPE_AUTH_TOKEN env var.
auth_token_file = "~/.config/duopipe/token.txt"

# Nostr node-id discovery is active whenever a config file is loaded. Both peers
# derive a shared nostr key from the auth_token above; the listener publishes its
# current ephemeral node id under its 'name' and the dialer looks it up by that
# name, so the node id never has to be exchanged by hand. The published node id is
# encrypted (NIP-44) under the shared auth_token-derived key, and the 'name' is
# hashed (salted with the auth_token) into the lookup key — so neither the node id
# nor the name can be read or guessed off the relays without the token. The
# auth_token still gates the actual connection.
#
# Relays default to a built-in public set; override here if you want specific ones:
# nostr_relay_urls = ["wss://nos.lol", "wss://relay.nostr.net"]

# Maximum concurrent forwarded data streams, shared across all connected peers
# (default: 100).
# max_streams = 100

# Custom relay server URL(s) for failover. Defaults to iroh's public relays.
# relay_urls = ["https://relay1.example.com", "https://relay2.example.com"]

# Force all traffic through the relay (disables direct P2P). Requires at least
# one entry in relay_urls (the public relay is rate-limited and not allowed here).
# relay_only = true

# Custom DNS server URL for iroh endpoint discovery (pkarr), or "none" to disable
# DNS discovery. NOT system DNS; does not affect destination resolution.
# NOTE: URL must include the /pkarr path. Both peers must match.
# dns_server = "https://dns.example.com/pkarr"
# dns_server = "none"

# ============================================================================
# Tunnel request template: each entry prefills a tunnel for every connected peer —
# ask that peer to connect out to 'remote_source' and deliver traffic to a local
# listener bound at 'local_listen'. The 'remote_source' scheme (tcp:// or udp://)
# selects the protocol. 'name' is the label shown in the TUI. Entries are just
# prefilled rows; nothing starts until you activate it (Enter in the TUI, or
# DUOPIPE_AUTOSTART_REQUESTS=1 in test mode). You can also add tunnels at runtime
# in the TUI with `a`.
# ============================================================================
[[request]]
name = "db"
remote_source = "tcp://127.0.0.1:5678"
local_listen = "127.0.0.1:15678"

[[request]]
name = "cache"
remote_source = "tcp://127.0.0.1:5679"
local_listen = "127.0.0.1:15679"

# ============================================================================
# Allowed source networks the peer may request of US (CIDR notation).
# Separate lists for TCP and UDP. Supports IPv4 and IPv6.
# Empty/omitted lists default to dual-stack localhost (127.0.0.0/8, ::1/128).
# ============================================================================
[allowed_sources]
tcp = [
    "127.0.0.0/8",      # localhost
    "192.168.0.0/16",   # private network
    "::1/128",          # IPv6 localhost
]
udp = [
    "10.0.0.0/8",       # private network
]

# ============================================================================
# Transport Tuning (Optional)
# ============================================================================
# Fine-tune the QUIC transport layer. All values have sensible defaults.
[transport]
# Congestion controller: cubic (default), bbr, or newreno.
# congestion_controller = "cubic"

# QUIC per-stream receive window in bytes (default: 67108864 = 64MB).
# Valid range: 1024 (1KB) to 67108864 (64MB).
# receive_window = 67108864

# QUIC send window in bytes (default: 67108864 = 64MB).
# send_window = 67108864

# QUIC ACK-eliciting threshold (default: unset = iroh/quinn default cadence).
# Leave unset unless you have measured a benefit. 0 = ACK every packet.
# Valid range: 0 to 65535.
# ack_eliciting_threshold = 2
