# duopipe peer configuration example
#
# Usage: duopipe start -c peer.toml
#        duopipe start --default-config   # loads ~/.config/duopipe/peer.toml
#
# `duopipe start` is interactive: on startup the TUI asks whether to connect to an
# existing instance. The role (dial/listen), the target node id, and (if missing)
# the auth token are answered there — they are NOT config keys. This file supplies
# the rest: the shared auth token, tunnel requests, the allowlist, relays, tuning.
#
# Tunnel model: each side always *requests* tunnels from the other. A [[request]]
# binds a local listener and asks the peer to connect out to a remote 'source';
# traffic is bridged between them. Requests do NOT start automatically — the TUI
# lists them and you start/stop each one with Enter (in test mode only, with
# DUOPIPE_TEST_MODE=1, set DUOPIPE_AUTOSTART_REQUESTS=1 to auto-start all on connect).
#
# Trust model: once token auth succeeds the peer is trusted to *ask*, but when it
# requests one of OUR sources we only honor addresses inside [allowed_sources]
# (separate CIDR lists per protocol). Empty/absent TCP or UDP defaults to
# dual-stack localhost.
#
# Node id: by default the iroh identity key is ephemeral (regenerated every run),
# so a listening instance's node id changes between runs. Set 'identity_file'
# (below) to persist the key and keep a stable node id.

# The shared auth token, presented by both sides. Optional: a fresh listening
# instance generates one if absent (shown in the TUI). Generate with:
#   duopipe generate-auth-token
# Supply it via 'auth_token_file' (recommended) or the DUOPIPE_AUTH_TOKEN env var.
auth_token_file = "~/.config/duopipe/token.txt"

# Persisted iroh identity for a STABLE node id (config-file mode only). When set,
# the file is read if present; on first run, if it is missing, you are asked to
# confirm before a new key is generated and written (mode 0o600). Leave unset for
# an ephemeral identity (a fresh node id every run, the default).
# identity_file = "~/.config/duopipe/identity.key"

# Maximum concurrent data streams per connection (default: 100).
# max_streams = 100

# Custom relay server URL(s) for failover. Defaults to iroh's public relays.
# relay_urls = ["https://relay1.example.com", "https://relay2.example.com"]

# Force all traffic through the relay (disables direct P2P). Requires at least
# one entry in relay_urls (the public relay is rate-limited and not allowed here).
# relay_only = true

# Custom DNS server URL for iroh endpoint discovery (pkarr), or "none" to disable
# DNS discovery. NOT system DNS; does not affect destination resolution.
# NOTE: URL must include the /pkarr path. Both peers must match.
# dns_server = "https://dns.example.com/pkarr"
# dns_server = "none"

# ============================================================================
# Tunnel requests: ask the peer to connect out to 'remote_source'; deliver traffic
# to a local listener bound at 'local_listen'. The 'remote_source' scheme (tcp://
# or udp://) selects the protocol. 'name' is the label shown in the TUI. Nothing
# starts until you activate it (Enter in the TUI, or DUOPIPE_AUTOSTART_REQUESTS=1
# in test mode).
# ============================================================================
[[request]]
name = "db"
remote_source = "tcp://127.0.0.1:5678"
local_listen = "127.0.0.1:15678"

[[request]]
name = "cache"
remote_source = "tcp://127.0.0.1:5679"
local_listen = "127.0.0.1:15679"

# ============================================================================
# Allowed source networks the peer may request of US (CIDR notation).
# Separate lists for TCP and UDP. Supports IPv4 and IPv6.
# Empty/omitted lists default to dual-stack localhost (127.0.0.0/8, ::1/128).
# ============================================================================
[allowed_sources]
tcp = [
    "127.0.0.0/8",      # localhost
    "192.168.0.0/16",   # private network
    "::1/128",          # IPv6 localhost
]
udp = [
    "10.0.0.0/8",       # private network
]

# ============================================================================
# Transport Tuning (Optional)
# ============================================================================
# Fine-tune the QUIC transport layer. All values have sensible defaults.
[transport]
# Congestion controller: cubic (default), bbr, or newreno.
# congestion_controller = "cubic"

# QUIC per-stream receive window in bytes (default: 67108864 = 64MB).
# Valid range: 1024 (1KB) to 67108864 (64MB).
# receive_window = 67108864

# QUIC send window in bytes (default: 67108864 = 64MB).
# send_window = 67108864

# QUIC ACK-eliciting threshold (default: unset = iroh/quinn default cadence).
# Leave unset unless you have measured a benefit. 0 = ACK every packet.
# Valid range: 0 to 65535.
# ack_eliciting_threshold = 2
